generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  lastname  String?
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  product   Products[]
  goal Goal?
}

model Products {
  id        Int      @id @default(autoincrement())
  foodname  String
  calories  Float
  protein   Float
  carbs     Float
  fats      Float
  mealType  String
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}


model Goal {
  id Int @id @default(autoincrement())

  calories_goal Float
  protein_goal Float
  carbs_goal Float
  fats_goal Float

  userId Int @unique
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}


